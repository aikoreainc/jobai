                  <option value="헤드헌팅 관련 네트워크">헤드헌팅 관련 네트워크</option>
                  <option value="호텔 관련 네트워크">호텔 관련 네트워크</option>
                  <option value="화장품 관련 네트워크">화장품 관련 네트워크</option>
              </select>
          </div>
          <p class="text-sm text-slate-500 dark:text-slate-400 mt-2 italic">※ 이미지를 클릭하시면 확대해서 볼 수 있습니다.</p>
        </div>
        <div class="w-full lg:w-2/3 flex justify-center items-center bg-gray-50 dark:bg-slate-900 rounded-xl p-4 min-h-[300px]">
          <img id="network-image" src="/images/jobai/network_all_240920.png" alt="워드 네트워크 맵" class="max-h-[500px] object-contain rounded-lg shadow-sm cursor-pointer transition transform hover:scale-105" onclick="openModal(this.src)" />
        </div>
      </div>
    </div>
  </div>

  <!-- Global Modal for Image Enlarge -->
  <div id="imageModal" class="fixed inset-0 z-50 hidden bg-slate-900/90 backdrop-blur-sm flex justify-center items-center p-4 transition-opacity duration-300" onclick="closeModal()">
    <div class="relative max-w-7xl w-full flex justify-center items-center" onclick="event.stopPropagation()">
      <button class="absolute -top-14 right-2 text-white hover:text-gray-300 transition text-5xl leading-none" onclick="closeModal()">&times;</button>
      <img id="modalImageRender" src="" class="max-h-[90vh] object-contain rounded-xl shadow-2xl bg-white dark:bg-slate-950 p-2" />
    </div>
  </div>

  <script is:inline>
    // Document setup for interactive components
    document.addEventListener('DOMContentLoaded', function() {
      // Network graph switcher
      const selectEl = document.getElementById('community-select');
      const imgEl = document.getElementById('network-image');
      if (selectEl && imgEl) {
        selectEl.addEventListener('change', function(e) {
          const val = e.target.value;
          if (val === 'all') {
            imgEl.src = '/images/jobai/network_all_240920.png';
          } else {
            imgEl.src = '/images/jobai/' + val + '.png';
          }
        });
      }
    });

    // Modal Image Enlarger
    window.openModal = function(src) {
      const modal = document.getElementById('imageModal');
      const modalImg = document.getElementById('modalImageRender');
      if (modal && modalImg) {
        modalImg.src = src;
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden'; // Stop background scrolling
      }
    };

    window.closeModal = function() {
      const modal = document.getElementById('imageModal');
      if (modal) {
        modal.classList.add('hidden');
        document.body.style.overflow = ''; // Resume background scrolling
      }
    };
  </script>
</Layout>
